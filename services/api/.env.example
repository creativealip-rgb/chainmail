# Chainmail API env
NODE_ENV=production
PORT=3000

# Postgres (chainmail-pg container, dokploy-network)
DATABASE_URL=postgres://chainmail:chainmail@chainmail-pg:5432/chainmail

# JWT secrets (CHANGE for production)
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-recommended-please
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-recommended-please
